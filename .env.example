# Databricks
DATABRICKS_HOST=https://your-databricks-host.cloud.databricks.com
DATABRICKS_TOKEN=dapi_xxxxx
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id

# Google (Apps Script Web App)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GOOGLE_TEMPLATE_DOC_ID=your-template-doc-id
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id
GOOGLE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json

# LLM (via LiteLLM proxy)
LITELLM_API_KEY=your-litellm-api-key
LITELLM_BASE_URL=https://your-litellm-proxy.example.com/v1
LITELLM_MODEL=gemini/gemini-2.0-flash

# Pipeline config
LEXIA_TARGET_PROCESSES=0000001-00.2026.0.00.0001,0000002-00.2026.0.00.0002
LEXIA_SPREADSHEET_ID=your-google-spreadsheet-id

# Processing
DAYS_BACK=12
LOG_LEVEL=INFO
