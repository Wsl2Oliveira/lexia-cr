# Databricks
DATABRICKS_HOST=https://nubank-e2-general.cloud.databricks.com
DATABRICKS_TOKEN=dapi_xxxxx
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id

# Nubank APIs (certificate auth)
NU_CERT_PATH=/path/to/client.pem
NU_CERT_KEY_PATH=/path/to/client-key.pem
NU_AUTH_URL=https://prod-global-auth.nubank.com.br/api/token

# Google (service account)
GOOGLE_CREDENTIALS_PATH=~/.config/lexia/google-credentials.json
GOOGLE_TEMPLATE_DOC_ID=your-template-doc-id
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Processing
DAYS_BACK=12
LOG_LEVEL=INFO
